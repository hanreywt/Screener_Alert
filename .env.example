# Copy this file to .env and fill in your values.
#   cp .env.example .env
# The engine auto-loads .env on startup (see config.py).

# --- Discord (channel webhook) ---------------------------------------------
# Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# Separate channel for the daily 07:00 WIB market report (web app only; set it
# in Vercel). Left unset = no report is sent. It deliberately does NOT fall back
# to DISCORD_WEBHOOK_URL, so a misconfig stays quiet instead of posting reports
# into the trading-alert channel.
DISCORD_SUMMARY_WEBHOOK_URL=

# --- Telegram (optional) ----------------------------------------------------
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
